version: "0.1"

include:
  - path: ../../modules/superpowers/AgentMakefile
  - path: ../../modules/unknown-repo-security/AgentMakefile
    as: security

metadata:
  name: runtime-walkthrough-demo
  description: End-to-end demo for prompt fragments, runtime planning, output validation, tool interception, sandbox preflight, and fallback handling.

compile:
  targets:
    - agents-md
    - claude-md
    - agents-fragments
    - claude-fragments
    - claude-skill
    - codex-skill
    - skills-index

policies:
  demo.output_contract:
    description: Require a structured runtime review result that can be validated with JSON Schema.
    output_schema:
      type: object
      required:
        - summary
        - findings
        - safe_next_steps
      properties:
        summary:
          type: string
          minLength: 10
        findings:
          type: array
          minItems: 1
          items:
            type: object
            required:
              - severity
              - message
            properties:
              severity:
                type: string
                enum:
                  - low
                  - medium
                  - high
              message:
                type: string
                minLength: 5
            additionalProperties: false
        safe_next_steps:
          type: array
          minItems: 1
          items:
            type: string
        risky_scripts:
          type: array
          items:
            type: string
        dependency_risks:
          type: array
          items:
            type: string
        tool_interception:
          type: object
        validation_status:
          type: string
          enum:
            - valid
            - invalid
      additionalProperties: false

targets:
  demo.runtime_walkthrough:
    extends: security.repo.security_review
    priority: 95
    match:
      user_intent:
        - runtime walkthrough
        - demo runtime planning
        - show agentmakefile runtime
    skills:
      - superpowers:using-superpowers
    add_policies:
      - demo.output_contract
    add_steps:
      - action: select_runtime_target
      - action: link_prompt_fragments
      - action: validate_structured_output
      - action: evaluate_provider_tool_interception
      - action: report_cache_and_safety_trace
    add_output_format:
      - summary
      - findings
      - safe_next_steps
      - tool_interception
      - validation_status
    fallback:
      blocked:
        - summarize_blocked_tool_call
        - suggest_safe_static_alternative

permissions:
  rules:
    bash:
      "printf *": allow
      "touch *": allow
