# AgentMakefile module: Superpowers methodology
version: 0.1

metadata:
  name: superpowers-methodology
  description: Reusable Superpowers-style development workflows for coding agents.
  module_type: methodology-pack
  source_repo: obra/superpowers
  source_url: https://github.com/obra/superpowers

policies:
  use_relevant_skill:
    description: Before acting, identify and use a specialized skill when one applies.
    guards:
      - inspect_task_for_skill_match
      - state_selected_skill_or_reason_none_applies
      - prefer_specialized_skill_over_ad_hoc_reasoning

  plan_before_multi_step_work:
    description: For non-trivial implementation work, write a concrete plan before changing code.
    steps:
      - define_goal
      - inspect_context
      - identify_files_to_modify
      - split_work_into_small_testable_tasks
      - include_verification_for_each_task
    output_format:
      - goal
      - architecture
      - tasks
      - verification

  test_driven_development:
    description: For behavior changes, write the test first, watch it fail, implement the minimum code, then refactor while green.
    guards:
      - write_failing_test_before_production_code
      - run_test_to_confirm_red
      - implement_minimal_green_change
      - rerun_tests_before_refactor

  systematic_debugging:
    description: Reproduce failures, form hypotheses, test them one at a time, and fix root cause with regression coverage.
    steps:
      - reproduce_failure
      - inspect_recent_changes
      - form_hypotheses
      - test_hypotheses_one_at_a_time
      - identify_root_cause
      - add_regression_test
      - implement_fix

  verify_before_completion:
    description: Do not claim completion without fresh verification evidence.
    guards:
      - identify_command_that_proves_claim
      - run_full_verification_command
      - read_exit_code_and_output
      - report_actual_result

  review_feedback_rigorously:
    description: When receiving review feedback, evaluate technical correctness before implementing changes.
    steps:
      - read_feedback_completely
      - restate_requirement_or_ask
      - verify_against_codebase_reality
      - implement_actionable_items
      - rerun_verification

  use_superpowers_bootstrap:
    description: At task start, inspect available skills and select the relevant specialized workflow before acting.
    guards:
      - invoke_relevant_skill_before_response_or_action
      - announce_selected_skill_and_reason
      - follow_skill_workflow_before_ad_hoc_reasoning

  dispatch_independent_work:
    description: Split independent problem domains across parallel agents when tasks can proceed without shared state.
    steps:
      - identify_independent_domains
      - assign_one_concrete_scope_per_agent
      - keep_delegated_tasks_self_contained
      - integrate_and_verify_results

  execute_written_plan:
    description: Execute a written implementation plan task by task, reviewing the plan first and stopping on blockers.
    steps:
      - load_plan
      - review_plan_for_gaps
      - execute_tasks_in_order
      - run_each_verification
      - finish_development_branch

  finish_development_branch:
    description: Complete development by verifying tests, detecting workspace state, and choosing merge, PR, or cleanup flow.
    steps:
      - run_final_tests
      - detect_git_workspace_state
      - present_integration_options
      - execute_selected_completion_flow

  request_code_review:
    description: Request focused code review after substantial implementation or before merge, then address actionable feedback.
    steps:
      - identify_review_scope
      - provide_requirements_and_diff_context
      - evaluate_review_findings
      - fix_critical_and_important_findings

  isolate_feature_work:
    description: Prefer isolated workspaces for feature work and implementation plans to protect the current branch.
    guards:
      - detect_existing_worktree_before_creating_one
      - ask_before_creating_manual_worktree
      - avoid_overwriting_user_workspace_state

  write_skills_with_tdd:
    description: Treat skill authoring as TDD for process documentation using pressure scenarios and verification.
    steps:
      - define_pressure_scenario
      - observe_baseline_failure
      - write_minimal_skill_guidance
      - verify_agent_compliance
      - refactor_skill_to_close_loopholes

skills:
  using-superpowers:
    namespace: superpowers
    description: Select and follow the relevant specialized workflow before any task response or action.
    match:
      user_intent:
        - any development task
        - choose workflow
        - use superpowers
    guards:
      - inspect_available_skills
      - invoke_relevant_skill_first
      - announce_selected_skill
    steps:
      - inspect_available_project_and_installed_skills
      - select_relevant_skill
      - follow_skill_before_taking_action

  brainstorming:
    namespace: superpowers
    description: Refine rough ideas into clear goals and designs before implementation.
    match:
      user_intent:
        - brainstorm
        - design
        - clarify requirements
    steps:
      - ask_targeted_questions
      - explore_alternatives
      - present_design_in_reviewable_sections

  writing-plans:
    namespace: superpowers
    description: Convert an approved spec into bite-sized implementation tasks.
    match:
      user_intent:
        - write plan
        - break down spec
        - implementation plan
    steps:
      - map_file_responsibilities
      - create_small_ordered_tasks
      - include_test_commands
      - include_commit_points

  test-driven-development:
    namespace: superpowers
    description: Enforce red-green-refactor for behavior changes.
    match:
      user_intent:
        - implement
        - fix bug
        - refactor
    steps:
      - write_failing_test
      - confirm_test_fails
      - implement_minimal_code
      - confirm_test_passes
      - refactor_while_green

  systematic-debugging:
    namespace: superpowers
    description: Debug regressions and unexpected behavior systematically.
    match:
      user_intent:
        - debug
        - failing test
        - regression
    steps:
      - reproduce
      - inspect
      - hypothesize
      - test_hypothesis
      - fix_root_cause

  verification-before-completion:
    namespace: superpowers
    description: Require fresh evidence before completion claims.
    match:
      user_intent:
        - complete task
        - final response
        - commit
    steps:
      - identify_verification
      - run_verification
      - inspect_output
      - summarize_evidence

  receiving-code-review:
    namespace: superpowers
    description: Handle code review feedback with technical rigor.
    match:
      user_intent:
        - review feedback
        - address comments
        - re-review
    steps:
      - parse_feedback
      - evaluate_correctness
      - implement_or_push_back
      - verify

  requesting-code-review:
    namespace: superpowers
    description: Request focused review after implementation or before merge to catch requirement and quality gaps.
    match:
      user_intent:
        - request review
        - code review
        - before merge
    steps:
      - identify_base_and_head
      - summarize_implementation_scope
      - provide_requirements_context
      - address_actionable_feedback

  dispatching-parallel-agents:
    namespace: superpowers
    description: Delegate independent problem domains to parallel agents when work can proceed without shared state.
    match:
      user_intent:
        - parallel agents
        - independent tasks
        - multiple failures
    steps:
      - identify_independent_domains
      - create_focused_agent_tasks
      - dispatch_agents_in_parallel
      - integrate_verified_results

  executing-plans:
    namespace: superpowers
    description: Execute a written implementation plan in order with review checkpoints and explicit verification.
    match:
      user_intent:
        - execute plan
        - implement plan
        - follow written plan
    steps:
      - load_and_review_plan
      - execute_each_task
      - run_specified_verification
      - finish_development_branch

  finishing-a-development-branch:
    namespace: superpowers
    description: Finish completed implementation work by verifying, choosing integration flow, and cleaning up appropriately.
    match:
      user_intent:
        - finish branch
        - merge work
        - create pull request
        - complete development
    steps:
      - verify_tests_pass
      - detect_workspace_state
      - present_completion_options
      - execute_selected_option

  using-git-worktrees:
    namespace: superpowers
    description: Ensure feature work happens in an isolated workspace when appropriate.
    match:
      user_intent:
        - start feature work
        - isolated workspace
        - worktree
    guards:
      - detect_existing_isolation
      - ask_before_creating_worktree
      - avoid_nested_or_conflicting_worktrees
    steps:
      - inspect_git_workspace_state
      - create_or_reuse_isolated_workspace
      - verify_project_setup

  writing-skills:
    namespace: superpowers
    description: Create, edit, and verify reusable skills using a TDD-style process for process documentation.
    match:
      user_intent:
        - write skill
        - create skill
        - update skill
    steps:
      - define_pressure_scenario
      - observe_baseline_behavior
      - write_skill_guidance
      - verify_skill_behavior
      - refactor_skill_guidance

  subagent-driven-development:
    namespace: superpowers
    description: Dispatch isolated workers for scoped implementation tasks when a plan is ready.
    match:
      user_intent:
        - execute plan
        - parallel implementation
    steps:
      - assign_one_task_per_worker
      - review_spec_compliance
      - review_code_quality
      - integrate_verified_changes

targets:
  methodology.default:
    phony: true
    priority: 70
    description: Default Superpowers-style development workflow.
    policies:
      - use_relevant_skill
      - verify_before_completion
    skills:
      - superpowers:brainstorming
      - superpowers:writing-plans
      - superpowers:verification-before-completion
    output_format:
      - selected_skill
      - progress
      - verification_result

  methodology.plan:
    phony: true
    priority: 85
    description: Break requirements into a concrete implementation plan.
    policies:
      - use_relevant_skill
      - plan_before_multi_step_work
    skills:
      - superpowers:writing-plans
    output_format:
      - goal
      - architecture
      - tasks
      - verification

  methodology.code_change:
    phony: true
    priority: 90
    description: Implement behavior changes using TDD and verification.
    policies:
      - use_relevant_skill
      - test_driven_development
      - verify_before_completion
    skills:
      - superpowers:test-driven-development
      - superpowers:verification-before-completion
    output_format:
      - failing_test
      - implementation_summary
      - verification_result

  methodology.debug:
    phony: true
    priority: 90
    description: Debug failures through reproduction and root-cause analysis.
    policies:
      - systematic_debugging
      - verify_before_completion
    skills:
      - superpowers:systematic-debugging
      - superpowers:verification-before-completion
    output_format:
      - reproduction
      - root_cause
      - fix
      - verification_result

  methodology.review:
    phony: true
    priority: 85
    description: Review or address review feedback with technical rigor.
    policies:
      - review_feedback_rigorously
      - verify_before_completion
    skills:
      - superpowers:receiving-code-review
      - superpowers:verification-before-completion
    output_format:
      - findings
      - changes
      - verification_result

  methodology.bootstrap:
    phony: true
    priority: 95
    description: Select the relevant Superpowers workflow before beginning a task.
    policies:
      - use_superpowers_bootstrap
      - verify_before_completion
    skills:
      - superpowers:using-superpowers
      - superpowers:verification-before-completion
    output_format:
      - selected_skill
      - rationale
      - next_action

  methodology.parallel:
    phony: true
    priority: 85
    description: Dispatch independent work to parallel agents and integrate verified results.
    policies:
      - dispatch_independent_work
      - verify_before_completion
    skills:
      - superpowers:dispatching-parallel-agents
      - superpowers:verification-before-completion
    output_format:
      - independent_domains
      - delegated_tasks
      - verification_result

  methodology.execute_plan:
    phony: true
    priority: 88
    description: Execute a written plan in order with verification at each checkpoint.
    policies:
      - execute_written_plan
      - verify_before_completion
    skills:
      - superpowers:executing-plans
      - superpowers:finishing-a-development-branch
    output_format:
      - plan_review
      - completed_tasks
      - verification_result

  methodology.finish:
    phony: true
    priority: 80
    description: Finish a development branch after implementation and verification.
    policies:
      - finish_development_branch
      - verify_before_completion
    skills:
      - superpowers:finishing-a-development-branch
    output_format:
      - verification_result
      - integration_options
      - selected_completion_flow

  methodology.request_review:
    phony: true
    priority: 84
    description: Request and handle focused code review for completed implementation work.
    policies:
      - request_code_review
      - review_feedback_rigorously
      - verify_before_completion
    skills:
      - superpowers:requesting-code-review
      - superpowers:receiving-code-review
    output_format:
      - review_scope
      - findings
      - changes

  methodology.worktree:
    phony: true
    priority: 75
    description: Prepare an isolated workspace for feature work when appropriate.
    policies:
      - isolate_feature_work
    skills:
      - superpowers:using-git-worktrees
    output_format:
      - workspace_state
      - setup_result

  methodology.skill_authoring:
    phony: true
    priority: 82
    description: Create or update reusable skills with test-first process documentation.
    policies:
      - write_skills_with_tdd
      - test_driven_development
      - verify_before_completion
    skills:
      - superpowers:writing-skills
      - superpowers:test-driven-development
      - superpowers:verification-before-completion
    output_format:
      - pressure_scenario
      - skill_changes
      - verification_result
